{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "🚀 Start Hot Reload Development",
			"type": "shell",
			"command": "${workspaceFolder}/dev-hotreload.bat",
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"isBackground": true,
			"problemMatcher": [],
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "new",
				"showReuseMessage": true,
				"clear": false
			}
		},
		{
			"label": "🐍 Start Python Backend Only",
			"type": "shell",
			"command": "python",
			"args": ["-m", "uvicorn", "server:app", "--reload", "--port", "8001"],
			"options": {
				"cwd": "${workspaceFolder}/backend"
			},
			"group": "build",
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "new"
			},
			"isBackground": true,
			"problemMatcher": []
		},
		{
			"label": "⚛️ Start React Frontend Only",
			"type": "shell",
			"command": "npm",
			"args": ["start"],
			"options": {
				"cwd": "${workspaceFolder}/frontend"
			},
			"group": "build",
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "new"
			},
			"isBackground": true,
			"problemMatcher": []
		},
		{
			"label": "🧪 Quick Test Runner",
			"type": "shell",
			"command": "${workspaceFolder}/test-runner.bat",
			"group": "test",
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": true,
				"panel": "new"
			}
		},
		{
			"label": "📊 Service Status",
			"type": "shell",
			"command": "powershell",
			"args": ["-File", "${workspaceFolder}/quick-actions.ps1", "status"],
			"group": "build",
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": true,
				"panel": "new"
			}
		},
		{
			"label": "🧹 Clean Environment",
			"type": "shell",
			"command": "powershell",
			"args": ["-File", "${workspaceFolder}/quick-actions.ps1", "clean"],
			"group": "build",
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": true,
				"panel": "new"
			}
		},
		{
			"label": "📦 Build Production",
			"type": "shell",
			"command": "npm",
			"args": ["run", "build"],
			"options": {
				"cwd": "${workspaceFolder}/frontend"
			},
			"group": "build",
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": true,
				"panel": "new"
			}
		}
	]
}